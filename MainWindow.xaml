<!-- MainWindow.xaml -->
<Window
    x:Class="WallTrek.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:WallTrek"
    xmlns:views="using:WallTrek.Views"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    mc:Ignorable="d">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="48"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom Title Bar Drag Region -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent"/>

        <!-- Content Area -->
        <views:MainView x:Name="MainViewControl" Grid.Row="1"
                       Visibility="Visible"/>
        <views:SettingsView x:Name="SettingsViewControl" Grid.Row="1"
                           Visibility="Collapsed"/>
        <views:ImageGridView x:Name="ImageGridViewControl" Grid.Row="1"
                            Visibility="Collapsed"/>
    </Grid>
</Window>